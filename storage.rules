rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /groups/{groupId}/evidence/{fileName} {
      // Allow read/write if the user is authenticated. 
      // In a real production environment, you would verify group membership here.
      allow read, write: if isSignedIn();
    }
  }
}